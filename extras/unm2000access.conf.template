# ${HOME} will be replaced by user home directory according to platform
default_userdir="${HOME}/.${APPNAME}/dev"
default_mac_userdir="${HOME}/Library/Application Support/${APPNAME}/dev"

# options used by the launcher by default, can be overridden by explicit
# command line switches
default_options="-J-Xverify:none -J-javaagent:/opt/unm2000/lib/hookagent.jar -J-Xbootclasspath/a:/opt/unm2000/lib/activation.jar --locale en:us --nologging --branding unm2000access -J-Xms512m -J-Xmx1024m   -J-XX:+HeapDumpOnOutOfMemoryError -J-XX:HeapDumpPath=./ -J-Dnetbeans.exception.alert.min.level=999999  -J-Dnetbeans.exception.report.min.level=999999 -J-Dsun.java2d.xrender=false -J-Dsun.java2d.opengl=false -J-Dsun.java2d.pmoffscreen=false -J--add-exports=jdk.internal.jvmstat/sun.jvmstat.monitor=ALL-UNNAMED -J--add-opens=java.desktop/javax.swing.plaf.basic=ALL-UNNAMED -J--add-opens=java.desktop/sun.awt=ALL-UNNAMED -J--add-opens=java.base/java.net=ALL-UNNAMED -J--add-opens=java.base/java.lang=ALL-UNNAMED -J--add-opens=java.desktop/java.awt=ALL-UNNAMED -J--add-opens=java.desktop/sun.awt.image=ALL-UNNAMED -J--add-opens=java.desktop/com.sun.java.swing.plaf.gtk=ALL-UNNAMED"
# for development purposes you may wish to append: -J-Dnetbeans.logger.console=true -J-ea

# default location of JDK/JRE, can be overridden by using --jdkhome <dir> switch
jdkhome="/usr/lib/jvm/temurin-21-jre-amd64"

# clusters' paths separated by path.separator (semicolon on Windows, colon on Unices)
#extra_clusters=
